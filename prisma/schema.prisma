generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  company   String?
  phone     String?
  interest  String?
  message   String?
  source    String?  @default("home")
  createdAt DateTime @default(now())
}

// Embeddings for semantic search on blog posts
// Populated via POST /embeddings/sync — requires OPENAI_API_KEY
model PostEmbedding {
  id        Int                      @id @default(autoincrement())
  slug      String                   @unique
  title     String
  summary   String?
  embedding Unsupported("vector(768)")?
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt
}
